{
  "manifest_version": 3,
  "name": "BlendUz Token Helper",
  "short_name": "BlendUz",
  "version": "0.2.2",
  "description": "Captures your Qobuz user_auth_token from play.qobuz.com so linking BlendUz becomes a one-click copy.",

  "permissions": [
    "webRequest",
    "storage"
  ],

  "host_permissions": [
    "https://*.qobuz.com/*"
  ],

  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },

  "icons": {
    "16":  "icon16.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "BlendUz Token Helper",
    "default_icon": {
      "16":  "icon16.png",
      "48":  "icon48.png",
      "128": "icon128.png"
    }
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "blenduz-token-helper@evilo.eu",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
